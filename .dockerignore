docs/
README.md
CONTRIBUTING.md
CODE_OF_CONDUCT.md
DESIGN.md
PRODUCT.md
KICKOFF.md
PYPREP_DESIGN_REVIEW_RESPONSE.md

# Local databases
*.db
*.db-journal

# Env files (mounted at runtime, not baked in)
.env
.env.local
.env-example
.env.example
.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.example

# Build artifacts
build/
dist/
*.egg-info/

# Scripts (pre-commit hooks; not needed at runtime)
scripts/

# Agent/skill metadata
.agents/
.claude/
skills-lock.json
.pre-commit-config.yaml

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Misc handoff artifacts
GIT_STATUS.txt
RECENT_COMMITS.txt
pyprep.db
