__pycache__/
*.pyc
*.pyo
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.hypothesis/

# Node — rebuilt in stage 1
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Tests (not needed at runtime)
tests/

# Coverage artifacts
.coverage
coverage-report/
htmlcov/

