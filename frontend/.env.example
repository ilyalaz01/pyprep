# Vite reads VITE_* env vars at build/dev start (not on hot-reload).
# Copy this file to `.env.local` (gitignored) before running `pnpm dev`.
# Restart the dev server after any change here.
#
# T6.0 / ADR-020: Pyodide CDN is pinned by version encoded inline in the
# URL path. Any version change is a deliberate VITE_PYODIDE_CDN diff that
# touches harness tests.

VITE_PYODIDE_CDN=https://cdn.jsdelivr.net/pyodide/v0.26.4/full/
