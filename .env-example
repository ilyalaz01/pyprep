# PyPrep — Environment Variables (example)
# Copy to .env and adjust. NEVER commit .env.

# --- App identity ---
PYPREP_ENV=development                  # development | production
PYPREP_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
PYPREP_LOG_JSON=false                   # true in production for structured logs

# --- Database ---
PYPREP_DATABASE_URL=sqlite:///./pyprep.db
# Example for prod: postgresql+psycopg://user:pass@host:5432/pyprep

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# REQUIRED. MUST be ≥ 32 characters (HS256 brute-force resistance, T2.5.1).
PYPREP_SECRET_KEY=replace-me-with-a-long-random-string-at-least-32-chars
PYPREP_JWT_TTL_DAYS=7
# Password length floor at registration. Range 4..128. Default 8.
# Note: bcrypt silently truncates passwords longer than 72 BYTES (UTF-8);
# the AuthService rejects them with PasswordTooLongError.
PYPREP_PASSWORD_MIN_LENGTH=8

# --- Owner / single-user mode ---
PYPREP_SINGLE_USER=true                 # skip registration UI, auto-login
PYPREP_SINGLE_USER_EMAIL=ilya@local.dev
PYPREP_SINGLE_USER_NAME=Ilya

# --- FSRS Spaced Repetition ---
PYPREP_FSRS_REQUEST_RETENTION=0.9       # target retrievability at next review
PYPREP_FSRS_MAXIMUM_INTERVAL_DAYS=36500
PYPREP_DAILY_NEW_CARD_CAP=15

# --- Content ---
PYPREP_CONTENT_DIR=./content
PYPREP_CONTENT_HOT_RELOAD=true          # dev only

# --- Frontend (Vite reads VITE_*) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_PYODIDE_CDN=https://cdn.jsdelivr.net/pyodide/v0.26.4/full/
VITE_PYODIDE_VERSION=0.26.4

# --- CORS ---
PYPREP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate limits (gatekeeper, currently unused but seam exists) ---
PYPREP_RATE_LIMIT_PER_MINUTE=120
